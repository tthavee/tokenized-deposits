# Sepolia testnet deployment (optional — local Hardhat runs without any of these)

# Required for Sepolia deployment
# Use either Alchemy or Infura:
# SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
SEPOLIA_RPC_URL=

# Private key of the operator wallet used to sign Sepolia transactions (no 0x prefix)
OPERATOR_PRIVATE_KEY=

# Optional — enables Etherscan contract verification after deployment
# npx hardhat verify --network sepolia <CONTRACT_ADDRESS>
ETHERSCAN_API_KEY=
