{
  "name": "tokenized-deposits-contracts",
  "version": "1.0.0",
  "description": "Hardhat project for DepositToken ERC-20 smart contract",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node --save-state .hardhat-state.json",
    "node:resume": "hardhat node --load-state .hardhat-state.json --save-state .hardhat-state.json",
    "node:reset": "rimraf .hardhat-state.json && hardhat node --save-state .hardhat-state.json",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@types/node": "^20.0.0",
    "hardhat": "^2.22.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "firebase-admin": "^13.7.0"
  }
}
