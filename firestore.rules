rules_version = '2';

// All collections are accessible only via the backend service account (Admin SDK),
// which bypasses these rules entirely. Client-side access is denied for all collections.
service cloud.firestore {
  match /databases/{database}/documents {

    // KYC and wallet data — backend only
    match /clients/{clientId} {
      allow read, write: if false;
    }

    // Deposit/withdrawal transaction records — backend only
    match /transactions/{txId} {
      allow read, write: if false;
    }

    // Deployed contract registry — backend only
    match /token_registry/{tokenId} {
      allow read, write: if false;
    }

    // System state (e.g. event listener checkpoint) — backend only
    match /system/{docId} {
      allow read, write: if false;
    }
  }
}