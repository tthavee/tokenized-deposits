rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Only the backend service account can read/write clients
    match /clients/{clientId} {
      allow read, write: if false;
    }

    // Only the backend service account can read/write transactions
    match /transactions/{txId} {
      allow read, write: if false;
    }

    // Only the backend service account can read/write token_registry
    match /token_registry/{tokenId} {
      allow read, write: if false;
    }

    // Only the backend service account can read/write system documents
    match /system/{docId} {
      allow read, write: if false;
    }
  }
}
